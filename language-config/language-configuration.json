{
  "comments": {
    "lineComment": "//"
  },

  "brackets": [
    ["(", ")"],
    ["[", "]"]
  ],

  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],

  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],

  "indentationRules": {

    "increaseIndentPattern": "^\\s*(si|sino\\s+si|sino|para|mientras|\\w+\\s*\\([^)]*\\)\\s*)\\s*$",

    "decreaseIndentPattern": "^\\s*(sino|sino\\s+si)\\b"
  },

  "folding": {
    "markers": {
      "start": "^\\s*(si|para|mientras|\\w+\\s*\\([^)]*\\))\\b",
      "end": "^\\s*(sino|sino\\s+si)\\b"
    }
  },

  "onEnterRules": [
    {
      "beforeText": "^\\s*//.*$",
      "action": {
        "indentAction": "none",
        "appendText": "// "
      }
    }
  ]
}