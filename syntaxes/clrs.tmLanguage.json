{
  "name": "CLRS Español",
  "scopeName": "source.clrs-es",
  "foldingStartMarker": "(\\bsi\\b|\\bpara\\b|\\bmientras\\b|\\w+\\s*\\()",
  "foldingStopMarker": "^\\s*(sino\\s+si|sino|fin)\\b",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#stdlib"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#calls"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.clrs",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.clrs",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.clrs"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.clrs"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.clrs",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.clrs",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.clrs",
          "match": "\\b(VERDAD|FALSO)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.conditional.elseif.clrs",
          "match": "\\bsino\\s+si\\b"
        },
        {
          "name": "keyword.control.conditional.clrs",
          "match": "\\b(si|sino)\\b"
        },
        {
          "name": "keyword.control.loop.clrs",
          "match": "\\b(para|mientras)\\b"
        },
        {
          "name": "keyword.control.loop.direction.clrs",
          "match": "\\b(hasta|bajando)\\b"
        },
        {
          "name": "keyword.control.io.clrs",
          "match": "\\b(escribir|leer|retornar)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.clrs",
          "match": "<-"
        },
        {
          "name": "keyword.operator.comparison.clrs",
          "match": "(<=|>=|!=|=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.clrs",
          "match": "(\\+|-|\\*|/|\\^|%)"
        },
        {
          "name": "keyword.operator.logical.clrs",
          "match": "\\b(y|o|no)\\b"
        }
      ]
    },
    "stdlib": {
      "patterns": [
        {
          "name": "support.function.clrs",
          "match": "\\b(AGREGA|ELIM|INSER|INDICE|CONT|ORDENA|INVER|COPIA|UNE|LANZAR_ERROR|LEER_ARCHIVO|EXISTE_ARCHIVO|PESO_ARCHIVO|CREAR_ARCHIVO|ESCRIBIR_ARCHIVO|ELIMINAR_ARCHIVO|ABS|MIN|MAX|REDONDEA|PISO|RAIZ|RAIZCUB|EXP|LOGN|LOG10|LOG2|SEN|COS|TAN|ARC|ARCOCOS|RAD|GRAD|PI|E|ALEAT|PROM|SUM|MED|VAR|LONG|CAR_EN|SUBCAD|MAYUS|MINUS|RECORTA|REEMP|DIV|ES_CAD_NUM|ES_VAC|EMP_CON|TERM_CON|ES_NUM|ES_CAD|ES_LOG|A_CAD|A_NUM|A_LOG)\\b(?=\\s*\\()"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.main.clrs",
          "begin": "\\b(PRINCIPAL)(\\s*)(\\()",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.main.clrs"
            },
            "3": {
              "name": "punctuation.section.parens.begin.clrs"
            }
          },
          "end": "\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.parens.end.clrs"
            }
          },
          "patterns": [
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#booleans"
            },
            {
              "include": "#variables"
            },
            {
              "include": "#operators"
            },
            {
              "name": "punctuation.separator.comma.clrs",
              "match": ","
            }
          ]
        },
        {
          "name": "meta.function.clrs",
          "begin": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\s*)(\\()",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.clrs"
            },
            "3": {
              "name": "punctuation.section.parens.begin.clrs"
            }
          },
          "end": "\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.parens.end.clrs"
            }
          },
          "patterns": [
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#booleans"
            },
            {
              "include": "#variables"
            },
            {
              "include": "#operators"
            },
            {
              "name": "punctuation.separator.comma.clrs",
              "match": ","
            }
          ]
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.assignment.clrs",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*<-)"
        },
        {
          "name": "meta.indexer.clrs",
          "begin": "\\[",
          "beginCaptures": {
            "0": {
              "name": "punctuation.section.brackets.begin.clrs"
            }
          },
          "end": "\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.section.brackets.end.clrs"
            }
          },
          "patterns": [
            {
              "include": "#numbers"
            },
            {
              "include": "#variables"
            },
            {
              "include": "#operators"
            }
          ]
        },
        {
          "name": "variable.other.array.clrs",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\[)"
        },
        {
          "name": "variable.other.clrs",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.parens.begin.clrs",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.clrs",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.clrs",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.clrs",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.clrs",
          "match": ","
        }
      ]
    }
  }
}