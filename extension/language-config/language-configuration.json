{
  "comments": {
    "lineComment": "//"
  },
  "wordPattern": "[A-Za-z_][A-Za-z0-9_]*",
  "brackets": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "\"",
      "close": "\""
    }
  ],
  "surroundingPairs": [
    [
      "(",
      ")"
    ],
    [
      "[",
      "]"
    ],
    [
      "\"",
      "\""
    ]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(si\\b.*|sino\\s+si\\b.*|para\\b.*|mientras\\b.*)$",
    "decreaseIndentPattern": "^\\s*sino(\\s+si)?\\b",
    "indentNextLinePattern": "^\\s*(si\\b.*|para\\b.*|mientras\\b.*)$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*//.*$",
      "action": {
        "indentAction": "none",
        "appendText": "// "
      }
    }
  ]
}