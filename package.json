{
  "name": "clrs-kit-esp",
  "displayName": "CLRS Kit Español",
  "description": "Soporte de lenguaje y herramientas para el lenguaje de pseudocódigo CRLS.",
  "version": "1.2.8",
  "publisher": "j-hernandez-dev",
  "icon": "./extension/images/icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Language Packs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/j-hernandez-dev/clrs-kit-esp.git"
  },
  "activationEvents": [],
  "main": "./extension/extension.js",
  "contributes": {
    "menus": {
      "editor/title": [
        {
          "command": "CLRS.runCode",
          "group": "navigation@1",
          "when": "resourceLangId == clrs-es"
        },
        {
          "command": "CLRS.toggleCost",
          "group": "navigation@2",
          "when": "resourceLangId == clrs-es"
        },
        {
          "command": "CLRS.toggleDiagram",
          "group": "navigation@3",
          "when": "resourceLangId == clrs-es"
        },
        {
          "command": "CLRS.generateCode",
          "group": "navigation@4",
          "when": "resourceLangId == clrs-es"
        },
        {
          "command": "CLRS.exportPNG",
          "group": "navigation@5",
          "when": "resourceLangId == clrs-es"
        }
      ]
    },
    "commands": [
      {
        "command": "CLRS.runCode",
        "title": "Ejecutar código CLRS",
        "icon": "$(play)"
      },
      {
        "command": "CLRS.toggleCost",
        "title": "Mostrar/ocultar costo algorítmico",
        "icon": "$(graph)"
      },
      {
        "command": "CLRS.toggleDiagram",
        "title": "Mostrar diagrama de flujo",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "CLRS.generateCode",
        "title": "Generar código JavaScript",
        "icon": "$(file-code)"
      },
      {
        "command": "CLRS.exportPNG",
        "title": "Exportar diagrama de flujo PNG",
        "icon": "$(file-media)"
      }
    ],
    "languages": [
      {
        "id": "clrs-es",
        "aliases": [
          "CLRS Español",
          "clrs-es"
        ],
        "extensions": [
          ".clrs"
        ],
        "configuration": "./extension/language-config/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "clrs-es",
        "scopeName": "source.clrs-es",
        "path": "./extension/syntaxes/clrs.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "clrs-es",
        "path": "./extension/snippets/clrs-core.code-snippets"
      },
      {
        "language": "clrs-es",
        "path": "./extension/snippets/clrs-math.code-snippets"
      },
      {
        "language": "clrs-es",
        "path": "./extension/snippets/clrs-file.code-snippets"
      },
      {
        "language": "clrs-es",
        "path": "./extension/snippets/clrs-string.code-snippets"
      },
      {
        "language": "clrs-es",
        "path": "./extension/snippets/clrs-array.code-snippets"
      },
      {
        "language": "clrs-es",
        "path": "./extension/snippets/clrs-type.code-snippets"
      },
      {
        "language": "clrs-es",
        "path": "./extension/snippets/clrs-error.code-snippets"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "chevrotain": "^12.0.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module"
}